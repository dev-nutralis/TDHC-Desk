generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Platform {
  id                     String          @id @default(uuid())
  name                   String
  slug                   String          @unique
  logo_url               String?
  website_url            String?
  transcription_language String?
  created_at             DateTime        @default(now())
  updated_at             DateTime        @updatedAt
  users                  UserPlatform[]
  klaviyo_forms          KlaviyoForm[]
}

model KlaviyoForm {
  id          String   @id @default(uuid())
  platform_id String
  name        String
  token       String   @unique
  mappings    Json     @default("[]")
  created_at  DateTime @default(now())
  platform    Platform @relation(fields: [platform_id], references: [id], onDelete: Cascade)
}

model User {
  id               String           @id @default(uuid())
  first_name       String
  last_name        String
  email            String           @unique
  password_hash    String
  role             String           @default("admin") // "super_admin" | "admin"
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  leads            Lead[]
  contacts         Contact[]
  deals            Deal[]
  deal_notes       DealNote[]
  calendar_events  CalendarEvent[]
  sip_account      SipAccount?
  calls            Call[]
  platforms        UserPlatform[]
}

model UserPlatform {
  id          String   @id @default(uuid())
  user_id     String
  platform_id String
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  platform    Platform @relation(fields: [platform_id], references: [id], onDelete: Cascade)
  created_at  DateTime @default(now())

  @@unique([user_id, platform_id])
}

model Source {
  id               String                 @id @default(uuid())
  name             String
  platform_id      String?
  created_at       DateTime               @default(now())
  updated_at       DateTime               @updatedAt
  attribute_groups SourceAttributeGroup[]
  leads            Lead[]
  contacts         Contact[]

  @@unique([name, platform_id])
}

model SourceAttributeGroup {
  id         String                @id @default(uuid())
  source_id  String
  source     Source                @relation(fields: [source_id], references: [id], onDelete: Cascade)
  name       String
  sort_order Int                   @default(0)
  items      SourceAttributeItem[]
}

model SourceAttributeItem {
  id         String               @id @default(uuid())
  group_id   String
  group      SourceAttributeGroup @relation(fields: [group_id], references: [id], onDelete: Cascade)
  label      String
  sort_order Int                  @default(0)
}

model ContactField {
  id              String               @id @default(uuid())
  label           String
  field_key       String
  field_type      String
  sort_order      Int                  @default(0)
  is_required     Boolean              @default(false)
  is_active       Boolean              @default(true)
  is_filterable   Boolean              @default(true)
  config          String?
  source_module   String?
  source_field_id String?
  platform_id     String?
  options         ContactFieldOption[]
  created_at      DateTime             @default(now())

  @@unique([field_key, platform_id])
}

model ContactFieldOption {
  id         String       @id @default(uuid())
  field_id   String
  field      ContactField @relation(fields: [field_id], references: [id], onDelete: Cascade)
  label      String
  value      String
  sort_order Int          @default(0)
}

model Contact {
  id            String            @id @default(uuid())
  field_values  Json?
  source_id     String?
  source        Source?           @relation(fields: [source_id], references: [id])
  attribute_ids String?
  user_id       String
  user          User              @relation(fields: [user_id], references: [id])
  platform_id   String?
  created_at    DateTime          @default(now())
  updated_at    DateTime          @updatedAt
  activities       ContactActivity[]
  deals            Deal[]
  calendar_events  CalendarEvent[]
}

model ContactActivity {
  id               String   @id @default(uuid())
  contact_id       String
  contact          Contact  @relation(fields: [contact_id], references: [id], onDelete: Cascade)
  type             String
  direction        String   @default("outbound")
  subject          String?
  body             String
  email_message_id String?  @unique
  deal_id          String?
  deal             Deal?    @relation(fields: [deal_id], references: [id], onDelete: SetNull)
  platform_id      String?
  archived         Boolean  @default(false)
  created_at       DateTime @default(now())
}

model Lead {
  id            String   @id @default(uuid())
  field_values  Json?
  source_id     String?
  source        Source?  @relation(fields: [source_id], references: [id])
  attribute_ids String?
  user_id       String
  user          User     @relation(fields: [user_id], references: [id])
  platform_id   String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
}

model LeadField {
  id            String            @id @default(uuid())
  label         String
  field_key     String
  field_type    String
  sort_order    Int               @default(0)
  is_required   Boolean           @default(false)
  is_active     Boolean           @default(true)
  is_filterable Boolean           @default(true)
  config        String?
  platform_id   String?
  options       LeadFieldOption[]
  created_at    DateTime          @default(now())

  @@unique([field_key, platform_id])
}

model LeadFieldOption {
  id         String    @id @default(uuid())
  field_id   String
  field      LeadField @relation(fields: [field_id], references: [id], onDelete: Cascade)
  label      String
  value      String
  sort_order Int       @default(0)
}

model ProfileFieldConfig {
  id         String   @id @default(uuid())
  field_key  String
  section    String
  sort_order Int      @default(0)
  is_visible Boolean  @default(true)
  platform_id String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([field_key, platform_id])
}

model EmailTemplate {
  id          String   @id @default(uuid())
  name        String
  subject     String?
  body        String
  platform_id String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model EmailSignature {
  id          String   @id @default(uuid())
  name        String
  body        String
  platform_id String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model Deal {
  id           String     @id @default(uuid())
  contact_id   String
  contact      Contact    @relation(fields: [contact_id], references: [id])
  field_values Json?
  user_id      String
  user         User       @relation(fields: [user_id], references: [id])
  platform_id  String?
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt
  notes            DealNote[]
  calendar_events  CalendarEvent[]
  activities       ContactActivity[]
}

model DealField {
  id              String            @id @default(uuid())
  label           String
  field_key       String
  field_type      String
  sort_order      Int               @default(0)
  is_required     Boolean           @default(false)
  is_active       Boolean           @default(true)
  is_filterable   Boolean           @default(true)
  config          String?
  source_module   String?
  source_field_id String?
  platform_id     String?
  options         DealFieldOption[]
  created_at      DateTime          @default(now())

  @@unique([field_key, platform_id])
}

model DealFieldOption {
  id         String    @id @default(uuid())
  field_id   String
  field      DealField @relation(fields: [field_id], references: [id], onDelete: Cascade)
  label      String
  value      String
  sort_order Int       @default(0)
}

model DealNote {
  id         String   @id @default(uuid())
  deal_id    String
  deal       Deal     @relation(fields: [deal_id], references: [id], onDelete: Cascade)
  user_id    String
  user       User     @relation(fields: [user_id], references: [id])
  content    String
  created_at DateTime @default(now())
}

model DealProfileConfig {
  id          String   @id @default(uuid())
  field_key   String
  section     String
  sort_order  Int      @default(0)
  is_visible  Boolean  @default(true)
  platform_id String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@unique([field_key, platform_id])
}

model CalendarEventTitle {
  id          String   @id @default(uuid())
  label       String
  sort_order  Int      @default(0)
  platform_id String?
  created_at  DateTime @default(now())

  @@unique([label, platform_id])
}

model CalendarEvent {
  id          String   @id @default(uuid())
  title       String
  description String?
  start_at    DateTime
  end_at      DateTime
  all_day     Boolean  @default(false)
  color       String   @default("#038153")
  completed   Boolean  @default(false)
  user_id     String
  user        User     @relation(fields: [user_id], references: [id])
  contact_id  String?
  contact     Contact? @relation(fields: [contact_id], references: [id], onDelete: SetNull)
  deal_id     String?
  deal        Deal?    @relation(fields: [deal_id], references: [id], onDelete: SetNull)
  platform_id String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model SipAccount {
  id         String   @id @default(uuid())
  user_id    String   @unique
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  extension  String   @unique
  sip_user   String
  sip_pass   String
  wss_host   String
  enabled    Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  calls      Call[]

  @@map("sip_account")
}

model Call {
  id             String    @id @default(uuid())
  unique_id      String    @unique
  direction      String
  caller_number  String
  callee_number  String
  status         String    @default("ringing")
  started_at     DateTime  @default(now())
  answered_at    DateTime?
  ended_at       DateTime?
  duration_sec   Int?
  hangup_cause   String?
  notes          String?
  recording_id       String?
  transcript         String?
  summary            String?
  transcript_status  String?
  contact_id         String?
  platform_id        String?
  sip_account_id String?
  sip_account    SipAccount? @relation(fields: [sip_account_id], references: [id], onDelete: SetNull)
  user_id        String?
  user           User?       @relation(fields: [user_id], references: [id], onDelete: SetNull)
  events         CallEvent[]

  @@index([sip_account_id])
  @@index([status])
  @@index([started_at])
  @@map("call")
}

model CallEvent {
  id         String   @id @default(uuid())
  call_id    String
  call       Call     @relation(fields: [call_id], references: [id], onDelete: Cascade)
  event_type String
  payload    String
  created_at DateTime @default(now())

  @@index([call_id])
  @@map("call_event")
}

model YeastarToken {
  id         String   @id
  token      String
  expires_at DateTime
  updated_at DateTime @updatedAt

  @@map("yeastar_token")
}
