{
  "regions": ["fra1"],
  "crons": [
    {
      "path": "/api/sms/poll",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/calls/recording-sync",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/calls/process-transcripts",
      "schedule": "* * * * *"
    }
  ],
  "functions": {
    "src/app/api/contacts/[id]/activities/route.ts": {
      "maxDuration": 15
    },
    "src/app/api/sip-credentials/route.ts": {
      "maxDuration": 15
    },
    "src/app/api/sms/poll/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/calls/recording-sync/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/calls/[id]/recording/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/calls/process-transcripts/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/calls/[id]/transcribe/route.ts": {
      "maxDuration": 60
    }
  }
}
